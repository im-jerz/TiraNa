# Database (for local dev only — Docker uses its own env vars)
DATABASE_URL=postgresql://user:password@localhost:5432/admin_airbnb

# Host Module API
HOST_API_URL=http://localhost:5000
HOST_API_KEY=your-api-key-here

# App
APP_ENV=development
SECRET_KEY=your-secret-key-here
OTP_EXPIRY_MINUTES=10

# SMTP (for OTP emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@airbnb-admin.com

# Database (Docker Compose uses 'postgres' as the host)
DATABASE_URL=postgresql://user:password@postgres:5432/admin_airbnb
# For local dev, change 'postgres' to 'localhost'

# Host Module API (mocked initially)
HOST_API_URL=http://localhost:5000
HOST_API_KEY=your-api-key-here

# App
APP_ENV=development
SECRET_KEY=your-secret-key-here

# SMTP (for OTP emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@airbnb-admin.com
OTP_EXPIRY_MINUTES=5
